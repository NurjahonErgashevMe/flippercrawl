# ===== Required ENVS ======
NUM_WORKERS_PER_QUEUE=8
PORT=3002
HOST=0.0.0.0
# API в контейнере: redis://redis:6379. Node на хосте + Redis из compose: redis://localhost:6380 (проброс в docker-compose)
REDIS_URL=redis://redis:6379
REDIS_RATE_LIMIT_URL=redis://redis:6379

# Postgres (docker compose: хост nuq-postgres)
POSTGRES_HOST=nuq-postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# Без Playwright — оставьте пустым
PLAYWRIGHT_MICROSERVICE_URL=

# LLM: OpenRouter (ключ + модель; альтернатива — OPENAI_API_KEY + OPENAI_BASE_URL)
OPENROUTER_API_KEY=
# По умолчанию https://openrouter.ai/api/v1 (OpenAI-compatible для AI SDK)
OPENROUTER_BASE_URL=
MODEL_NAME=z-ai/glm-4.7-flash

## To turn on DB authentication, you need to set up supabase.
USE_DB_AUTHENTICATION=false

# Только scrape (без crawl, map, search, extract, admin, bull board, agent WS)
API_SCRAPE_ONLY=true

# ===== Optional ENVS ======

# SearchApi key. Head to https://searchapi.com/ to get your API key
SEARCHAPI_API_KEY=
# SearchApi engine, defaults to google. Available options: google, bing, baidu, google_news, etc. Head to https://searchapi.com/ to explore more engines
SEARCHAPI_ENGINE=

## === Concurrency & Performance Settings ===
# NuQ: сколько процессов scrape-worker (nuq-worker). Каждый берёт один job = один URL;
# batch из 20 ссылок при self-hosted обрабатывается параллельно, если воркеров ≥ 20.
NUQ_WORKER_COUNT=20
NUQ_WORKER_START_PORT=3006
# Prefetch = START_PORT + WORKER_COUNT, reconciler = prefetch + 1 (при смене COUNT пересчитайте)
NUQ_PREFETCH_WORKER_PORT=3026
NUQ_RECONCILER_WORKER_PORT=3027

# Number of worker processes per queue - controls parallel job processing
# Recommended: 4-8 for most setups, adjust based on CPU cores
NUM_WORKERS_PER_QUEUE=8
# Number of concurrent crawl requests/pages - increase for higher throughput
# Recommended: 8-16 for most setups, 32+ for high-performance servers
CRAWL_CONCURRENT_REQUESTS=10

# Maximum number of simultaneous crawl jobs
# Controls how many crawl operations can run at the same time
MAX_CONCURRENT_JOBS=5

# Size of browser instance pool for Playwright service
# Higher values allow more parallel browser operations
BROWSER_POOL_SIZE=5

# Supabase Setup (used to support DB authentication, advanced logging, etc.)
SUPABASE_ANON_TOKEN=
SUPABASE_URL=
SUPABASE_SERVICE_TOKEN=

# Other Optionals
# use if you've set up authentication and want to test with a real API key
TEST_API_KEY=
# set if you'd like to test the scraping rate limit
RATE_LIMIT_TEST_API_KEY_SCRAPE=
# set if you'd like to test the crawling rate limit
RATE_LIMIT_TEST_API_KEY_CRAWL=
# set if you'd like to use scraping Be to handle JS blocking
SCRAPING_BEE_API_KEY=
# add for LLM dependent features (image alt generation, etc.)
OPENAI_API_KEY=
BULL_AUTH_KEY=@
# set if you have a llamaparse key you'd like to use to parse pdfs
LLAMAPARSE_API_KEY=
# set if you'd like to send slack server health status messages
SLACK_WEBHOOK_URL=
# set if you'd like to send posthog events like job logs
POSTHOG_API_KEY=
# set if you'd like to send posthog events like job logs
POSTHOG_HOST=

STRIPE_PRICE_ID_STANDARD=
STRIPE_PRICE_ID_SCALE=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_HOBBY=
STRIPE_PRICE_ID_HOBBY_YEARLY=
STRIPE_PRICE_ID_STANDARD_NEW=
STRIPE_PRICE_ID_STANDARD_NEW_YEARLY=
STRIPE_PRICE_ID_GROWTH=
STRIPE_PRICE_ID_GROWTH_YEARLY=

# set if you'd like to use the fire engine closed beta
FIRE_ENGINE_BETA_URL=

# Прокси для исходящих HTTP-запросов (fetch / PDF / sitemap). Пример: хост:порт или http://host:port
# Логин/пароль — отдельно (не дублируйте их в PROXY_SERVER, если задаёте USERNAME/PASSWORD).
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=

# Мобильный прокси с ротацией: GET URL от провайдера для смены IP (без прокси).
# При 403/429 и кодах из PROXY_ROTATION_STATUSES — вызов ссылки, сброс соединений, повтор запроса.
PROXY_ROTATION_URL=
PROXY_ROTATION_STATUSES=403,429
PROXY_ROTATION_MAX_ATTEMPTS=5
PROXY_ROTATION_COOLDOWN_MS=2500
PROXY_ROTATION_POST_DELAY_MS=1500
# При обрыве TCP к прокси: вызывать URL смены IP (если задан). false = только сброс соединений
PROXY_ROTATION_ON_TRANSPORT_ERROR=true

# Второй прокси (другой провайдер): после ротации основного при 403/429 запрос пойдёт через резерв;
# при повторных обрывах основного — переключение на резерв. Формат как у PROXY_SERVER.
PROXY_SERVER_FALLBACK=
PROXY_USERNAME_FALLBACK=
PROXY_PASSWORD_FALLBACK=
# Если у резервного провайдера появится GET для смены IP — задайте здесь (иначе только сброс соединений + PROXY_ROTATION_POST_DELAY_MS)
PROXY_FALLBACK_ROTATION_URL=

# set if you'd like to block media requests to save proxy bandwidth
BLOCK_MEDIA=

# Set this to the URL of your webhook when using the self-hosted version of FireCrawl
SELF_HOSTED_WEBHOOK_URL=

# Set this to the HMAC secret of your webhook when using the self-hosted version of FireCrawl
SELF_HOSTED_WEBHOOK_HMAC_SECRET=

# Resend API Key for transactional emails
RESEND_API_KEY=

# LOGGING_LEVEL determines the verbosity of logs that the system will output.
# Available levels are:
# NONE - No logs will be output.
# ERROR - For logging error messages that indicate a failure in a specific operation.
# WARN - For logging potentially harmful situations that are not necessarily errors.
# INFO - For logging informational messages that highlight the progress of the application.
# DEBUG - For logging detailed information on the flow through the system, primarily used for debugging.
# TRACE - For logging more detailed information than the DEBUG level.
# Set LOGGING_LEVEL to one of the above options to control logging output.
LOGGING_LEVEL=INFO



# x402 Payment Configuration
X402_PAY_TO_ADDRESS=
                    # ^ Address taken from -> https://portfolio.metamask.io/
X402_NETWORK=base-sepolia
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_ENABLED=true
X402_VERIFICATION_TIMEOUT=30000

CDP_API_KEY_ID=""
CDP_API_KEY_SECRET=""
                  # ^ KEYS taken from -> https://portal.cdp.coinbase.com/projects/api-keys

## ENDPOINT PRICING TEST $0.01
X402_ENDPOINT_PRICE_USD=0.01